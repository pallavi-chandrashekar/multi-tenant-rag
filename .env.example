# ---------------------------------------------------------------------------
# Enterprise RAG Reference Architecture -- example configuration
# Copy to `.env` and adjust. Sensible defaults let the stack boot with only an
# OPENAI_API_KEY set (embeddings run locally and need no key).
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://user:password@db:5432/ragdb

# --- LLM / generation -------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Embeddings -------------------------------------------------------------
# `local`  -> sentence-transformers all-MiniLM-L6-v2 (384 dim, no API key)
# `openai` -> OPENAI_EMBEDDING_MODEL (requires matching Vector() dimension)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=384

# --- Retrieval behaviour ----------------------------------------------------
RAG_TOP_K=5
RAG_MIN_CONFIDENCE_SCORE=0.55
RAG_ENABLE_HYBRID_RETRIEVAL=true
RAG_ENABLE_UNKNOWN_ANSWER=true
RAG_ENABLE_CITATIONS=true

# Hybrid fusion weights (combined = vector*W_v + keyword*W_k)
RAG_VECTOR_WEIGHT=0.7
RAG_KEYWORD_WEIGHT=0.3
RAG_VECTOR_FLOOR=0.35

# --- Cross-encoder reranking (optional) -------------------------------------
# When true, retrieve RAG_RERANK_CANDIDATES fused candidates and reorder them
# with a cross-encoder before truncating to RAG_TOP_K. Downloads the model on
# first use.
RAG_ENABLE_RERANKER=false
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_RERANK_CANDIDATES=20

# --- Vector store backend ---------------------------------------------------
# `pgvector` (default) or `hana` (stub adapter).
VECTOR_STORE=pgvector

# --- OpenTelemetry tracing (optional) ---------------------------------------
# No-op unless enabled; requires backend/requirements-otel.txt.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-rag
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
